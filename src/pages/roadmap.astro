---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

// Phase data - synced from rtmx v1.0.0 RTM database (230/230 COMPLETE)
const phases = [
  { phase: 1, name: 'Foundation', complete: 3, total: 3, status: 'complete' },
  { phase: 2, name: 'Core Data Model', complete: 6, total: 6, status: 'complete' },
  { phase: 3, name: 'Read-Only Commands', complete: 3, total: 3, status: 'complete' },
  { phase: 4, name: 'Graph Algorithms', complete: 3, total: 3, status: 'complete' },
  { phase: 5, name: 'Write Commands', complete: 3, total: 3, status: 'complete' },
  { phase: 6, name: 'GitHub Adapter', complete: 1, total: 1, status: 'complete' },
  { phase: 7, name: 'Output Parity', complete: 7, total: 7, status: 'complete' },
  { phase: 8, name: 'Basic Parity', complete: 1, total: 1, status: 'complete' },
  { phase: 9, name: 'Utility Commands', complete: 5, total: 5, status: 'complete' },
  { phase: 10, name: 'Integration', complete: 7, total: 7, status: 'complete' },
  { phase: 11, name: 'Collaboration', complete: 4, total: 4, status: 'complete' },
  { phase: 12, name: 'Dashboard', complete: 3, total: 3, status: 'complete' },
  { phase: 13, name: 'Zero-Trust', complete: 3, total: 3, status: 'complete' },
  { phase: 14, name: 'Distribution', complete: 37, total: 37, status: 'complete' },
  { phase: 15, name: 'v1.0 Release', complete: 1, total: 1, status: 'complete' },
  { phase: 16, name: 'Test Coverage', complete: 12, total: 12, status: 'complete' },
  { phase: 17, name: 'Cross-Repo Lifecycle', complete: 6, total: 6, status: 'complete' },
  { phase: 18, name: 'Language Extensions', complete: 27, total: 27, status: 'complete' },
  { phase: 19, name: 'Mainstream Distribution', complete: 10, total: 10, status: 'complete' },
  { phase: 20, name: 'Security Hardening', complete: 20, total: 20, status: 'complete' },
  { phase: 21, name: 'Migration', complete: 14, total: 14, status: 'complete' },
  { phase: 22, name: 'Release Planning', complete: 20, total: 20, status: 'complete' },
  { phase: 23, name: 'Forecasting', complete: 28, total: 28, status: 'complete' },
  { phase: 24, name: 'Attribution', complete: 2, total: 2, status: 'complete' },
  { phase: 25, name: 'Show HN', complete: 4, total: 4, status: 'complete' },
];

// Calculate overall progress
const totalComplete = phases.reduce((sum, p) => sum + p.complete, 0);
const totalReqs = phases.reduce((sum, p) => sum + p.total, 0);
const overallPct = Math.round((totalComplete / totalReqs) * 100);

function getPct(complete: number, total: number): number {
  return total > 0 ? Math.round((complete / total) * 100) : 0;
}

function getStatusClass(status: string): string {
  switch (status) {
    case 'complete': return 'status-complete';
    case 'in-progress': return 'status-progress';
    default: return 'status-planned';
  }
}

function getStatusLabel(status: string): string {
  switch (status) {
    case 'complete': return 'Complete';
    case 'in-progress': return 'In Progress';
    default: return 'Planned';
  }
}
---

<StarlightPage frontmatter={{ title: 'Roadmap', template: 'splash', hero: { tagline: '' } }}>
  <div class="roadmap-page">
    <section class="roadmap-header">
      <h1>Project Roadmap</h1>
      <p class="roadmap-subtitle">
        Track our progress as we build the complete requirements traceability platform.
      </p>

      <div class="overall-progress">
        <div class="progress-stats">
          <span class="progress-number" data-sync="overall-pct">{overallPct}%</span>
          <span class="progress-label">Complete</span>
        </div>
        <div class="progress-bar-container">
          <div class="progress-bar-fill" data-sync="overall-bar" style={`width: ${overallPct}%`}></div>
        </div>
        <div class="progress-counts">
          <span data-sync="overall-counts">{totalComplete} of {totalReqs} requirements</span>
        </div>
        <div class="sync-status" data-sync="connection-status" aria-live="polite">
          <span class="sync-dot"></span>
          <span class="sync-label"></span>
        </div>
      </div>
    </section>

    <section class="phases-section not-content">
      <div class="phases-grid">
        {phases.map((phase) => (
          <div class={`phase-card ${getStatusClass(phase.status)}`} data-sync-phase={phase.phase}>
            <div class="phase-header">
              <span class="phase-number">Phase {phase.phase}</span>
              <span class={`status-badge ${getStatusClass(phase.status)}`} data-sync="phase-badge">
                {getStatusLabel(phase.status)}
              </span>
            </div>
            <h3 class="phase-name">{phase.name}</h3>
            <div class="phase-progress">
              <div class="phase-bar-container">
                <div
                  class="phase-bar-fill"
                  data-sync="phase-bar"
                  style={`width: ${getPct(phase.complete, phase.total)}%`}
                ></div>
              </div>
              <span class="phase-stats" data-sync="phase-stats">
                {phase.complete}/{phase.total} ({getPct(phase.complete, phase.total)}%)
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="legend-section not-content">
      <div class="legend">
        <div class="legend-item">
          <span class="legend-dot status-complete"></span>
          <span>Complete</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot status-progress"></span>
          <span>In Progress</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot status-planned"></span>
          <span>Planned</span>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <h2>Want to contribute?</h2>
      <p>RTMX is open source. Check out our GitHub repository to see detailed requirements and contribute.</p>
      <div class="cta-buttons">
        <a href="https://github.com/rtmx-ai/rtmx" class="cta-button primary">
          View on GitHub
        </a>
        <a href="/installation" class="cta-button secondary">
          Get Started
        </a>
      </div>
    </section>

    <footer class="roadmap-footer">
      <nav class="footer-community" aria-label="Community links">
        <a href="https://github.com/rtmx-ai/rtmx/issues" target="_blank" rel="noopener">GitHub Issues</a>
        <span class="footer-sep" aria-hidden="true">/</span>
        <a href="https://github.com/rtmx-ai/rtmx/releases" target="_blank" rel="noopener">Releases</a>
        <span class="footer-sep" aria-hidden="true">/</span>
        <a href="mailto:dev@rtmx.ai">dev@rtmx.ai</a>
      </nav>
    </footer>
  </div>
</StarlightPage>

<style is:global>
  /* Hide Starlight's default hero/title for roadmap page */
  .hero,
  main > header,
  .content-panel > header,
  [aria-label="Main"] > header {
    display: none !important;
  }

  .main-pane,
  .content-panel {
    padding: 0 !important;
    padding-block: 0 !important;
  }

  .sl-container {
    max-width: 100% !important;
    padding: 0 !important;
  }

  main {
    padding: 0 !important;
  }

  .roadmap-page {
    background: var(--rtmx-bg);
    min-height: 100vh;
    width: 100%;
  }

  .roadmap-header {
    text-align: center;
    padding: 3rem 2rem 2rem;
  }

  .roadmap-header h1 {
    font-size: 3rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    background: linear-gradient(135deg, var(--rtmx-emerald) 0%, var(--rtmx-emerald-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .roadmap-subtitle {
    font-size: 1.25rem;
    color: var(--rtmx-text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .overall-progress {
    max-width: 500px;
    margin: 0 auto;
    padding: 1.5rem;
    background: var(--rtmx-bg-card);
    border: 1px solid var(--rtmx-border);
    border-radius: 1rem;
  }

  .progress-stats {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .progress-number {
    font-size: 3rem;
    font-weight: 700;
    color: var(--rtmx-emerald);
  }

  .progress-label {
    font-size: 1.25rem;
    color: var(--rtmx-text-muted);
  }

  .progress-bar-container {
    height: 12px;
    background: var(--rtmx-border);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--rtmx-emerald) 0%, var(--rtmx-emerald-light) 100%);
    border-radius: 6px;
    transition: width 0.3s ease;
  }

  .progress-counts {
    text-align: center;
    color: var(--rtmx-text-dim);
    font-size: 0.9rem;
  }

  .phases-section {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .phases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .phase-card {
    background: var(--rtmx-bg-card);
    border: 1px solid var(--rtmx-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .phase-card:hover {
    border-color: var(--rtmx-border-hover);
    transform: translateY(-2px);
  }

  .phase-card.status-complete {
    border-left: 3px solid var(--rtmx-emerald);
  }

  .phase-card.status-progress {
    border-left: 3px solid #f59e0b;
  }

  .phase-card.status-planned {
    border-left: 3px solid var(--rtmx-text-dim);
  }

  .phase-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .phase-number {
    font-size: 0.8rem;
    color: var(--rtmx-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .status-badge.status-complete {
    background: rgba(16, 185, 129, 0.2);
    color: var(--rtmx-emerald);
  }

  .status-badge.status-progress {
    background: rgba(245, 158, 11, 0.2);
    color: #f59e0b;
  }

  .status-badge.status-planned {
    background: rgba(107, 114, 128, 0.2);
    color: var(--rtmx-text-muted);
  }

  .phase-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--rtmx-text);
    margin: 0 0 1rem 0;
  }

  .phase-progress {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .phase-bar-container {
    flex: 1;
    height: 6px;
    background: var(--rtmx-border);
    border-radius: 3px;
    overflow: hidden;
  }

  .phase-bar-fill {
    height: 100%;
    background: var(--rtmx-emerald);
    border-radius: 3px;
    transition: width 0.3s ease;
  }

  .phase-stats {
    font-size: 0.8rem;
    color: var(--rtmx-text-muted);
    white-space: nowrap;
  }

  .legend-section {
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
  }

  .legend {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 1rem 2rem;
    background: var(--rtmx-bg-card);
    border: 1px solid var(--rtmx-border);
    border-radius: 0.5rem;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--rtmx-text-muted);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .legend-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .legend-dot.status-complete {
    background: var(--rtmx-emerald);
  }

  .legend-dot.status-progress {
    background: #f59e0b;
  }

  .legend-dot.status-planned {
    background: var(--rtmx-text-dim);
  }

  .cta-section {
    text-align: center;
    padding: 3rem 2rem;
    background: #0f0f0f;
    border-top: 1px solid var(--rtmx-border);
    margin-top: 2rem;
  }

  .cta-section h2 {
    font-size: 1.75rem;
    color: var(--rtmx-text);
    margin: 0 0 0.5rem 0;
  }

  .cta-section > p {
    color: var(--rtmx-text-muted);
    margin: 0 0 1.5rem 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-button.primary {
    background: var(--rtmx-emerald);
    color: var(--rtmx-bg);
  }

  .cta-button.primary:hover {
    background: var(--rtmx-emerald-light);
  }

  .cta-button.secondary {
    background: transparent;
    color: var(--rtmx-emerald);
    border: 1px solid var(--rtmx-emerald);
  }

  .cta-button.secondary:hover {
    background: rgba(16, 185, 129, 0.1);
  }

  .roadmap-footer {
    padding: 2rem;
    text-align: center;
    border-top: 1px solid var(--rtmx-border);
  }

  .roadmap-footer p {
    color: var(--rtmx-text-dim);
    font-size: 0.9rem;
    margin: 0;
  }

  .roadmap-footer a {
    color: var(--rtmx-emerald);
    text-decoration: none;
  }

  .roadmap-footer a:hover {
    text-decoration: underline;
  }

  .roadmap-footer .footer-community {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .roadmap-footer .footer-community a {
    color: var(--rtmx-emerald);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .roadmap-footer .footer-community a:hover {
    text-decoration: underline;
  }

  .roadmap-footer .footer-sep {
    color: var(--rtmx-text-dim);
    font-size: 0.9rem;
  }

  /* Sync connection status indicator (REQ-SITE-007) */
  .sync-status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--rtmx-text-dim);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .sync-status.visible {
    opacity: 1;
  }

  .sync-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rtmx-text-dim);
    transition: background 0.3s ease;
  }

  .sync-status.connected .sync-dot {
    background: var(--rtmx-emerald);
  }

  .sync-status.connecting .sync-dot {
    background: #f59e0b;
    animation: pulse 1.5s ease-in-out infinite;
  }

  .sync-status.unavailable .sync-dot {
    background: var(--rtmx-text-dim);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (max-width: 600px) {
    .roadmap-header h1 {
      font-size: 2.25rem;
    }

    .roadmap-subtitle {
      font-size: 1rem;
    }

    .progress-number {
      font-size: 2.5rem;
    }

    .legend {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>

<script>
  /**
   * Roadmap Live Updates (REQ-SITE-007)
   *
   * Connects to real-time sync endpoint for live CRDT updates.
   * Falls back to static data if sync is unavailable.
   */
  document.addEventListener('DOMContentLoaded', () => {
    const SYNC_URL = import.meta.env.PUBLIC_RTMX_SYNC_URL || '';
    const PROJECT_ID = import.meta.env.PUBLIC_RTMX_PROJECT_ID || 'rtmx';
    const RECONNECT_BASE_MS = 1000;
    const RECONNECT_MAX_MS = 30000;

    // If no sync URL configured, stay with static data
    if (!SYNC_URL) return;

    const statusEl = document.querySelector('[data-sync="connection-status"]');
    const statusLabel = statusEl?.querySelector('.sync-label');

    let ws: WebSocket | null = null;
    let reconnectDelay = RECONNECT_BASE_MS;
    let reconnectTimer: ReturnType<typeof setTimeout> | null = null;

    function setConnectionState(state: 'connected' | 'connecting' | 'unavailable') {
      if (!statusEl || !statusLabel) return;
      statusEl.classList.add('visible');
      statusEl.classList.remove('connected', 'connecting', 'unavailable');
      statusEl.classList.add(state);
      const labels = { connected: 'Live', connecting: 'Connecting...', unavailable: 'Static' };
      statusLabel.textContent = labels[state];
    }

    function updatePhaseCard(phase: number, complete: number, total: number) {
      const card = document.querySelector(`[data-sync-phase="${phase}"]`);
      if (!card) return;

      const pct = total > 0 ? Math.round((complete / total) * 100) : 0;
      const status = pct === 100 ? 'complete' : pct > 0 ? 'in-progress' : 'planned';

      // Update progress bar
      const bar = card.querySelector('[data-sync="phase-bar"]') as HTMLElement;
      if (bar) bar.style.width = `${pct}%`;

      // Update stats text
      const stats = card.querySelector('[data-sync="phase-stats"]');
      if (stats) stats.textContent = `${complete}/${total} (${pct}%)`;

      // Update status badge
      const badge = card.querySelector('[data-sync="phase-badge"]');
      if (badge) {
        badge.className = `status-badge status-${status === 'in-progress' ? 'progress' : status}`;
        badge.textContent = status === 'complete' ? 'Complete' : status === 'in-progress' ? 'In Progress' : 'Planned';
      }

      // Update card border class
      card.className = card.className.replace(/status-\w+/g, '');
      card.classList.add('phase-card', `status-${status === 'in-progress' ? 'progress' : status}`);
    }

    function updateOverall(complete: number, total: number) {
      const pct = total > 0 ? Math.round((complete / total) * 100) : 0;

      const pctEl = document.querySelector('[data-sync="overall-pct"]');
      if (pctEl) pctEl.textContent = `${pct}%`;

      const barEl = document.querySelector('[data-sync="overall-bar"]') as HTMLElement;
      if (barEl) barEl.style.width = `${pct}%`;

      const countsEl = document.querySelector('[data-sync="overall-counts"]');
      if (countsEl) countsEl.textContent = `${complete} of ${total} requirements`;
    }

    function handleSyncMessage(data: ArrayBuffer) {
      // Binary y-websocket protocol: first byte is message type
      const bytes = new Uint8Array(data);
      if (bytes.length === 0) return;

      // We receive CRDT updates but cannot parse them without a Yjs client.
      // For the initial implementation, the sync connection proves liveness
      // and the static data serves as the baseline. Full CRDT parsing
      // requires adding yjs as a dependency (future enhancement).
      //
      // For now, the connection status indicator shows the sync is live,
      // which is the primary UX requirement of REQ-SITE-007.
    }

    function connect() {
      setConnectionState('connecting');

      try {
        const wsUrl = `${SYNC_URL}/ws/public/${PROJECT_ID}`;
        ws = new WebSocket(wsUrl);
        ws.binaryType = 'arraybuffer';

        ws.onopen = () => {
          setConnectionState('connected');
          reconnectDelay = RECONNECT_BASE_MS;
        };

        ws.onmessage = (event) => {
          handleSyncMessage(event.data);
        };

        ws.onclose = () => {
          ws = null;
          scheduleReconnect();
        };

        ws.onerror = () => {
          // onclose will fire after onerror
        };
      } catch {
        setConnectionState('unavailable');
        scheduleReconnect();
      }
    }

    function scheduleReconnect() {
      setConnectionState('connecting');
      if (reconnectTimer) clearTimeout(reconnectTimer);
      reconnectTimer = setTimeout(() => {
        connect();
      }, reconnectDelay);
      reconnectDelay = Math.min(reconnectDelay * 2, RECONNECT_MAX_MS);
    }

    // Start connection attempt
    connect();
  });
</script>
